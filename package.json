{
  "name": "mini-agent",
  "version": "0.1.0",
  "description": "A Claude Code-style CLI agent built from scratch with the DeepSeek API — companion code for a 10-day tutorial",
  "type": "module",
  "bin": {
    "mini-agent": "dist/agent.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "tsx --env-file=.env src/agent.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx --env-file=.env eval/run.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.6"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "openai": "^6.42.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
