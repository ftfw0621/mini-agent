# mini-agent works with ANY OpenAI-compatible API.
#
# Quick start — DeepSeek, the default (get a key at https://platform.deepseek.com):
DEEPSEEK_API_KEY=sk-your-key

# ---- Bring your own provider (overrides the DeepSeek defaults) --------------
# Three variables, that's all:
#
# MINI_AGENT_API_KEY=sk-...
# MINI_AGENT_BASE_URL=https://api.openai.com/v1
# MINI_AGENT_MODEL=gpt-4.1-mini
#
# Known-good shapes (model names drift — check your provider's docs):
#   OpenAI:      MINI_AGENT_BASE_URL=https://api.openai.com/v1
#   Kimi:        MINI_AGENT_BASE_URL=https://api.moonshot.cn/v1
#   Qwen:        MINI_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   GLM (Zhipu): MINI_AGENT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   OpenRouter:  MINI_AGENT_BASE_URL=https://openrouter.ai/api/v1
#   Ollama:      MINI_AGENT_BASE_URL=http://localhost:11434/v1   MINI_AGENT_API_KEY=ollama
#
# Requirements & caveats:
# - The model MUST support function calling (tool use). Reasoning-only models
#   and many small local models will not work well.
# - Context window: the compaction trigger assumes DeepSeek's ~1M tokens.
#   If your model's window is smaller, set it (in tokens):
# MINI_AGENT_CONTEXT_WINDOW=128000
#
# Tip: `npm run eval` doubles as a model benchmark — same 10 cases, any model.
